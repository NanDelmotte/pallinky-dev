{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["./*"],
      "@pallinky/ui": ["../../packages/ui/src"],
      "@pallinky/ui/*": ["../../packages/ui/src/*"],
      "@pallinky/core": ["../../packages/core/src"],
      "@pallinky/core/*": ["../../packages/core/src/*"]
    },
    "incremental": true,
    "isolatedModules": true,
    "jsx": "preserve"
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../../packages/ui/src/**/*.ts",
    "../../packages/ui/src/**/*.tsx",
    "../../packages/core/src/**/*.ts",
    "../../packages/core/src/**/*.tsx"
  ]
}